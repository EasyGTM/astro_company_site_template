{
  "name": "services-company-template",
  "version": "1.0.0",
  "description": "A high-performance Astro template for modern services companies.",
  "author": "Skynet",
  "license": "MIT",
  "packageManager": "npm@10.9.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"astro dev\"",
    "build": "node scripts/themeGenerator.js && astro build",
    "preview": "astro preview",
    "preset:apply": "node scripts/applyPreset.mjs",
    "preset:list": "node scripts/applyPreset.mjs --list",
    "check": "astro check",
    "lint": "prettier -c . && eslint astro.config.mjs eslint.config.mjs scripts/*.js scripts/*.mjs",
    "validate": "npm run lint && npm run check && npm run build",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/mdx": "4.3.13",
    "@astrojs/react": "4.4.2",
    "@astrojs/sitemap": "3.6.0",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "astro": "5.16.5",
    "astro-auto-import": "^0.4.5",
    "date-fns": "^4.1.0",
    "github-slugger": "^2.0.0",
    "marked": "^17.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "sharp": "^0.34.5",
    "vite": "^7.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "24.10.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-bootstrap-grid": "^6.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
