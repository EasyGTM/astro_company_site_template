---
import Base from "./Base.astro";

const { frontmatter } = Astro.props;
---

<Base
  title={frontmatter.title}
  meta_title={frontmatter.meta_title}
  description={frontmatter.description}
>
  <section class="pt-32 pb-20 px-6 md:px-10">
    <div class="max-w-4xl mx-auto">
      <div
        class="prose dark:prose-invert max-w-none prose-headings:font-primary prose-a:text-primary dark:prose-a:text-darkmode-primary hover:prose-a:opacity-80 transition-colors"
      >
        <slot />
      </div>
    </div>
  </section>
</Base>
