---
import { getCollection, render } from "astro:content";
import Base from "@/layouts/Base.astro";
import { absoluteUrl, buildBreadcrumbSchema } from "@/lib/site";

export async function getStaticPaths() {
  const work = await getCollection("work", ({ data }) => !data.draft);
  return work.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const caseStudyUrl = absoluteUrl(`/work/${entry.id}`);

const schema = [
  buildBreadcrumbSchema([
    { name: "Home", item: absoluteUrl("/") },
    { name: "Work", item: absoluteUrl("/work") },
    { name: entry.data.title, item: caseStudyUrl },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: entry.data.title,
    description: entry.data.description,
    url: caseStudyUrl,
    image: absoluteUrl(entry.data.image),
    about: entry.data.services,
  },
];
---

<Base
  title={entry.data.title}
  meta_title={entry.data.meta_title}
  description={entry.data.description}
  image={entry.data.image}
  schema={schema}
>
  <section class="section pt-36">
    <div class="container max-w-6xl">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-start">
        <div class="fade-in-section">
          <span class="eyebrow">{entry.data.client}</span>
          <h1 class="type-h1 mt-4">{entry.data.title}</h1>
          <p class="type-lead mt-6 max-w-3xl">{entry.data.description}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            {
              entry.data.services.map((service) => (
                <span class="rounded-full border border-border bg-white/70 px-4 py-2 text-sm text-text dark:border-darkmode-border dark:bg-darkmode-light/70 dark:text-darkmode-text">
                  {service}
                </span>
              ))
            }
          </div>
        </div>

        <aside
          class="fade-in-section rounded-[2rem] border border-border bg-white/90 p-8 shadow-[0_24px_80px_rgba(16,24,40,0.06)] dark:border-darkmode-border dark:bg-theme-darkmode-body/90"
        >
          <img
            src={entry.data.image}
            alt={entry.data.title}
            class="mb-6 rounded-[1.5rem]"
            loading="lazy"
          />
          <div class="space-y-6">
            <div>
              <p
                class="text-sm font-bold uppercase tracking-widest text-text-dark dark:text-darkmode-text-dark"
              >
                Sector
              </p>
              <p class="mt-2 text-text dark:text-darkmode-text">
                {entry.data.sector}
              </p>
            </div>
            <div>
              <p
                class="text-sm font-bold uppercase tracking-widest text-text-dark dark:text-darkmode-text-dark"
              >
                Engagement
              </p>
              <p class="mt-2 text-text dark:text-darkmode-text">
                {entry.data.engagement}
              </p>
            </div>
            <div>
              <p
                class="text-sm font-bold uppercase tracking-widest text-text-dark dark:text-darkmode-text-dark"
              >
                Duration
              </p>
              <p class="mt-2 text-text dark:text-darkmode-text">
                {entry.data.duration}
              </p>
            </div>
          </div>
        </aside>
      </div>

      <div class="mt-16 grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
        <div
          class="fade-in-section rounded-[1.75rem] border border-border bg-light/70 p-8 dark:border-darkmode-border dark:bg-darkmode-light/70"
        >
          <h2 class="type-h3 mb-6">Outcomes</h2>
          <ul class="space-y-3 text-text dark:text-darkmode-text">
            {entry.data.results.map((result) => <li>• {result}</li>)}
          </ul>
          {
            entry.data.quote && (
              <blockquote class="mt-8 border-l-4 border-primary pl-5 text-text dark:text-darkmode-text">
                “{entry.data.quote}”
                {entry.data.quote_author && (
                  <footer class="mt-3 text-sm font-bold uppercase tracking-widest text-text-light dark:text-darkmode-text-light">
                    {entry.data.quote_author}
                  </footer>
                )}
              </blockquote>
            )
          }
        </div>
        <div class="content fade-in-section">
          <Content />
        </div>
      </div>
    </div>
  </section>
</Base>
