---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Page not found"
  description="The page you requested does not exist. Return to the homepage or browse the main template sections."
  noindex={true}
>
  <section class="section pt-40">
    <div class="container max-w-3xl text-center">
      <div
        class="fade-in-section rounded-[2rem] border border-border bg-white/80 p-10 dark:border-darkmode-border dark:bg-theme-darkmode-body/80"
      >
        <span class="eyebrow">404</span>
        <h1 class="type-h1 mt-4">That page is missing.</h1>
        <p class="type-lead mt-6">
          Try the homepage, services, work, or insights sections instead.
        </p>
        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
          <a href="/" class="btn btn-primary-cta">Go home</a>
          <a href="/services" class="btn btn-outline-primary">Browse services</a
          >
        </div>
      </div>
    </div>
  </section>
</Base>
