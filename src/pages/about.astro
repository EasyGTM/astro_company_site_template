---
import { render } from "astro:content";
import Base from "@/layouts/Base.astro";
import { getPage } from "@/lib/content";
import { buildBreadcrumbSchema, absoluteUrl } from "@/lib/site";

const aboutPage = await getPage("about");

if (!aboutPage) {
  throw new Error("Missing about page content entry.");
}

const { Content } = await render(aboutPage);

const schema = buildBreadcrumbSchema([
  { name: "Home", item: absoluteUrl("/") },
  { name: "About", item: absoluteUrl("/about") },
]);
---

<Base
  title={aboutPage.data.title}
  meta_title={aboutPage.data.meta_title}
  description={aboutPage.data.description}
  image={aboutPage.data.image}
  schema={schema}
>
  <section class="section pt-36">
    <div class="container max-w-5xl">
      <div class="fade-in-section">
        <span class="eyebrow">{aboutPage.data.kicker}</span>
        <h1 class="type-h1 mt-4">
          {aboutPage.data.hero_title || aboutPage.data.title}
        </h1>
        <p class="type-lead mt-6 max-w-3xl">{aboutPage.data.hero_intro}</p>
      </div>
      <div class="content mt-14 fade-in-section">
        <Content />
      </div>
    </div>
  </section>
</Base>
